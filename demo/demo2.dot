digraph CFG {
  0 [label="0: a = [1, 2, 3]"];
  0 -> 1;
  1 [label="1: b = [4, 5, 6]"];
  1 -> 2;
  2 [label="2: offset = [0, 0, 1]"];
  2 -> 3;
  3 [label="3: sum = b + offset"];
  3 -> 4;
  4 [label="4: loopSeed = a->0"];
  4 -> 5;
  5 [label="5: loopLimit = 3"];
  5 -> 6;
  6 [label="6: first = a->0"];
  6 -> 7;
  7 [label="7: while (loopSeed < loopLimit)"];
  7 -> 8 [label="true"];
  7 -> 10 [label="false"];
  8 [label="8: loopValue = sum + b"];
  8 -> 9;
  9 [label="9:  print(loopValue)"];
  9 -> 7;
  10 [label="10: if (first > 0)"];
  10 -> 11 [label="true"];
  10 -> 12 [label="false"];
  11 [label="11:  print(sum)"];
  12 [label="12:  print(a)"];
}
